# Copy to .env.local and fill in values (never commit .env.local)
#
# Find your project ID: sanity.io/manage → your project → Project settings

# Public Sanity identifiers (also set on Vercel)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# "staging" = show drafts locally (same as stage.simonask.io on Vercel Preview)
# NEXT_PUBLIC_SITE_ENV=staging

# Studio URL for Presentation / draft preview (local dev or hosted)
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
# NEXT_PUBLIC_SANITY_STUDIO_URL=https://simonask.sanity.studio

# Server-only: Viewer token from sanity.io/manage → API → Tokens
SANITY_API_READ_TOKEN=

# Server-only: random string for Sanity webhook → /api/revalidate
SANITY_REVALIDATE_SECRET=

# Google Tag Manager (Web + server-side — plan Steps 5–13)
NEXT_PUBLIC_GTM_WEB_CONTAINER_ID=GTM-KR894J8P
# Server GTM / Stape tagging URL (set on Web GA4 tag as server_container_url)
# NEXT_PUBLIC_GTM_SERVER_URL=https://serverside.simonask.io

# Contact form (Resend — https://resend.com)
# 1. Add and verify simonask.io in Resend → Domains
# 2. Create an API key → paste below
# 3. Add the same vars on Vercel (Production + Preview)
RESEND_API_KEY=
# Sender must use a verified Resend domain (mail.simonask.io)
CONTACT_FROM_EMAIL=hello@mail.simonask.io
