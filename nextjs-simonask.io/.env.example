# Copy to .env.local for local overrides (never commit .env.local)

# Public Sanity identifiers (safe to expose)
NEXT_PUBLIC_SANITY_PROJECT_ID=au2uzesy
NEXT_PUBLIC_SANITY_DATASET=production

# Set to "staging" on stage.simonask.io only (Vercel env var)
# NEXT_PUBLIC_SITE_ENV=staging

# Studio URL for Presentation / draft preview (local or deployed studio)
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# Server-only: Viewer token from sanity.io/manage → API → Tokens
# Required for draft preview on staging and in Presentation tool
SANITY_API_READ_TOKEN=

# Server-only: random string for Sanity webhook → /api/revalidate
SANITY_REVALIDATE_SECRET=
