# Copy to .env.local and fill in values (never commit .env.local)
#
# Use the same project ID as website (.env.local there).
# Find it: sanity.io/manage → your project → Project settings

SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Where the Next.js site runs when using Presentation preview
SANITY_STUDIO_PREVIEW_ORIGIN=http://localhost:3000
