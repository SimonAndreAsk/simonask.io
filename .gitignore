# Local-only (not shared)
.local/

# Dependencies (website, cms, repo root)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Environment variables and secrets (never commit)
.env
.env.*
!.env.example
!**/.env.example
*.key
secrets/

# Private keys and certificates
*.pem
*.p12
*.pfx

# Website — Next.js
website/.next/
website/out/
website/test-results/
next-env.d.ts

# CMS — Sanity Studio
cms/dist/
cms/.sanity/
cms/logs/

# Shared build / tooling artifacts
dist/
.sanity/
.next/
out/
/build
coverage/
*.tsbuildinfo

# Vercel
.vercel/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS and editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
